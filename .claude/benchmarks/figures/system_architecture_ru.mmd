flowchart TB
  classDef appLayer fill:#EBF5FB,stroke:#2980B9,stroke-width:2px,color:#2C3E50
  classDef coreLayer fill:#EAFAF1,stroke:#27AE60,stroke-width:2px,color:#1E8449
  classDef dataLayer fill:#FDEDEC,stroke:#C0392B,stroke-width:2px,color:#922B21
  classDef agentLayer fill:#FEF9E7,stroke:#F39C12,stroke-width:2px,color:#B9770E

  subgraph Client ["Tauri Desktop Приложение"]
    direction TB
    UI["React 18 + TypeScript<br>(Управление состоянием Zustand)"]:::appLayer
  end

  subgraph Core ["Rust Оптимизационный Backend"]
    direction TB
    API["Axum HTTP API"]:::coreLayer
    OPT["Diet Engine<br>(good_lp, auto-populate)"]:::coreLayer
    DB_Access["Коннектор SQLite<br>(rusqlite)"]:::coreLayer
  end

  subgraph DataLayer ["Локальное Хранилище (БД)"]
    direction TB
    DB[("База данных SQLite<br>(Нормы и Конфигурации)")]:::dataLayer
    JSON[("Артефакты кормовой базы<br>(JSON)")]:::dataLayer
  end
  
  subgraph AgentLayer ["Локальный ИИ Агент"]
    direction TB
    AGENT["Ollama API Интерфейс"]:::agentLayer
    LLM["Qwen 3.5 4B<br>(Анализ и оценка рационов)"]:::agentLayer
  end

  UI <==>|"JSON / REST"| API
  API <==>|"Линейное программирование"| OPT
  API <==>|"SQL Запросы"| DB_Access
  DB_Access <==>|"Чтение / Запись"| DB
  API -.->|"Чтение файлов"| JSON
  API <==>|"Промпты / HTTP"| AGENT
  AGENT <==>|"Локальный инференс"| LLM
