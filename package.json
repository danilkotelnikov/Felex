{
  "name": "felex",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"cargo run --bin felex-server\" \"vite\"",
    "build:feed-runtime": "python scripts/build_feed_runtime_artifacts.py",
    "build": "npm run build:feed-runtime && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "build:installer": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
