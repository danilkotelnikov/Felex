    "react-hot-toast": "^2.4.1",
    "react-i18next": "^16.5.4",
    "react-markdown": "^9.0.1",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
